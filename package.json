{
  "name": "collage-creator",
  "version": "1.0.0",
  "description": "Desktop collage slideshow creator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "serve": "node serve.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.collage.creator",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "icon": "assets/icon.icns"
    }
  }
}