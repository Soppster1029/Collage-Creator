{
  "name": "collage-creator",
  "version": "1.0.0",
  "productName": "Collage Creator",
  "description": "Desktop collage slideshow creator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "serve": "node serve.js",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "publish": {
      "provider": "github"
    },
    "appId": "com.collage.creator",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico",
      "publisherName": "Collage Creator Team"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "mac": {
      "icon": "assets/icon.icns"
    },
    "linux": {
      "maintainer": "Collage Creator Team",
      "target": ["AppImage", "deb", "rpm"],
      "icon": "assets/icon.png"
    }
  }
}